# LLM
PRIMARY_MODEL=ollama/llama3
OLLAMA_API_BASE=http://localhost:11434
# FALLBACK_MODEL=

# Optional channels
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# Optional alerts
# TELEGRAM_ALERT_CHAT_ID=
# DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Memory / Qdrant
# DATA_DIR can be a local path or an HTTP Qdrant URL.
DATA_DIR=data/qdrant_storage
SEMANTIC_EXTRACTION_ENABLED=true
SEMANTIC_SIMILARITY_THRESHOLD=0.85
SUMMARIZATION_ENABLED=true
SUMMARIZATION_TURN_THRESHOLD=10
LESSON_EXTRACTION_ENABLED=true
LESSON_CONSOLIDATION_THRESHOLD=20

# MCP Servers
# Fetch and Playwright require no API key.
# Brave Search: free tier 2,000 queries/month — https://brave.com/search/api/
# BRAVE_API_KEY=

# Logging
LOG_LEVEL=INFO

# Cloud fallback keys are intentionally omitted from the default local-first
# template. Re-enable them later only if you configure a cloud FALLBACK_MODEL.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
