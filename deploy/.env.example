# ── LLM ─────────────────────────────────────────────────────────────────────
PRIMARY_MODEL=ollama/llama3
# PRIMARY_MODEL=anthropic/claude-sonnet-4-6
# PRIMARY_MODEL=openai/gpt-4o

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_API_BASE=http://localhost:11434

# ── Channels ─────────────────────────────────────────────────────────────────
# Telegram bot (get token from @BotFather)
# TELEGRAM_BOT_TOKEN=...

# Chat ID to receive dead man's switch alerts (your personal chat or a group)
# TELEGRAM_ALERT_CHAT_ID=...

# Discord bot token (from Discord Developer Portal)
# DISCORD_BOT_TOKEN=...

# Discord webhook URL for one-shot alerts (channel → Integrations → Webhooks)
# DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Memory ───────────────────────────────────────────────────────────────────
DATA_DIR=data/qdrant_storage

# ── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Memory behaviour ─────────────────────────────────────────────────────────
SEMANTIC_EXTRACTION_ENABLED=true
SEMANTIC_SIMILARITY_THRESHOLD=0.85
SUMMARIZATION_ENABLED=true
SUMMARIZATION_TURN_THRESHOLD=10
LESSON_EXTRACTION_ENABLED=true
LESSON_CONSOLIDATION_THRESHOLD=20
